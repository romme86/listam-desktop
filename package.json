{
  "name": "listam-desktop",
  "version": "0.19.4",
  "private": true,
  "type": "module",
  "main": "index.html",
  "pear": {
    "name": "listam",
    "type": "desktop",
    "gui": {
      "width": 1280,
      "height": 860,
      "backgroundColor": "#101212"
    },
    "stage": {
      "ignore": [
        "/.git",
        "/.github",
        "/.gitignore",
        "/.DS_Store",
        "/test",
        "/design-guide",
        "/installer",
        "/listam-desktop-secrets.json"
      ]
    }
  },
  "scripts": {
    "dev": "pear run --dev .",
    "test": "node --test --test-force-exit test/*.test.mjs",
    "lint": "eslint .",
    "ci": "npm run lint && npm run test"
  },
  "dependencies": {
    "@listam/backend": "file:../listam-packages/packages/backend",
    "@listam/client": "file:../listam-packages/packages/client",
    "@listam/domain": "file:../listam-packages/packages/domain",
    "@listam/grocery": "file:../listam-packages/packages/grocery",
    "@listam/i18n": "file:../listam-packages/packages/i18n",
    "@listam/logging": "file:../listam-packages/packages/logging",
    "@listam/owner-control": "file:../listam-packages/packages/owner-control",
    "@listam/protocol": "file:../listam-packages/packages/protocol",
    "@listam/provisioning": "file:../listam-packages/packages/provisioning",
    "@listam/secrets": "file:../listam-packages/packages/secrets",
    "autobase": "^7.20.0",
    "b4a": "^1.7.1",
    "bare-fs": "^4.4.4",
    "bare-path": "^3.0.1",
    "bare-rpc": "^0.2.12",
    "bare-subprocess": "^5.2.3",
    "bare-tcp": "^2.5.1",
    "bare-url": "^2.4.3",
    "blind-pairing": "^2.3.1",
    "corestore": "^7.5.0",
    "hypercore-crypto": "^3.6.1",
    "hyperswarm": "^4.12.1",
    "sodium-universal": "^5.0.1",
    "z32": "^1.1.0"
  },
  "devDependencies": {
    "eslint": "^9.39.1",
    "hyperdht": "^6.27.0",
    "typescript-eslint": "^8.46.4"
  },
  "overrides": {
    "@listam/protocol": "file:../listam-packages/packages/protocol",
    "@listam/provisioning": "file:../listam-packages/packages/provisioning",
    "@listam/domain": "file:../listam-packages/packages/domain",
    "@listam/logging": "file:../listam-packages/packages/logging",
    "@listam/secrets": "file:../listam-packages/packages/secrets",
    "@listam/grocery": "file:../listam-packages/packages/grocery",
    "@listam/i18n": "file:../listam-packages/packages/i18n",
    "@listam/owner-control": "file:../listam-packages/packages/owner-control",
    "@listam/client": "file:../listam-packages/packages/client",
    "@listam/backend": "file:../listam-packages/packages/backend"
  }
}

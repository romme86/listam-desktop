    "ci": "npm run lint && npm run test"
  },
  "dependencies": {
    "@listam/backend": "^0.8.0",
    "@listam/client": "^0.8.0",
    "@listam/domain": "^0.7.0",
    "@listam/grocery": "^0.7.0",
    "@listam/i18n": "^0.9.0",
    "@listam/logging": "^0.7.0",
    "@listam/protocol": "^0.7.0",
    "@listam/secrets": "^0.7.0"
  },
  "devDependencies": {
    "eslint": "^9.39.1",
    "hyperdht": "^6.27.0",
    "typescript-eslint": "^8.46.4"
  }
}

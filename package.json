{
  "name": "listam-desktop",
  "version": "0.12.0",
  "private": true,
  "type": "module",
  "main": "index.html",
  "pear": {
    "name": "listam",
    "type": "desktop",
    "gui": {
      "width": 1280,
      "height": 860,
      "backgroundColor": "#fbf9f9"
    }
  },
  "scripts": {
    "dev": "pear run --dev .",
    "test": "node --test --test-force-exit test/*.test.mjs",

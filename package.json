{
  "name": "listam-desktop",
  "version": "0.12.0",
  "private": true,
  "type": "module",
  "main": "index.html",
  "pear": {
    "name": "listam",
    "type": "desktop",
    "gui": {
      "width": 1280,
      "height": 860,
      "backgroundColor": "#fbf9f9"
    }
  },
  "scripts": {
    "dev": "pear run --dev .",
    "test": "node --test --test-force-exit test/*.test.mjs",
    "lint": "eslint .",
    "ci": "npm run lint && npm run test"
  },
  "dependencies": {
    "@listam/backend": "file:../listam-packages/packages/backend",
    "@listam/client": "file:../listam-packages/packages/client",
    "@listam/domain": "file:../listam-packages/packages/domain",
    "@listam/grocery": "file:../listam-packages/packages/grocery",
    "@listam/i18n": "file:../listam-packages/packages/i18n",
    "@listam/logging": "file:../listam-packages/packages/logging",
    "@listam/protocol": "file:../listam-packages/packages/protocol",
    "@listam/secrets": "file:../listam-packages/packages/secrets"
  },
  "devDependencies": {
    "eslint": "^9.39.1",
    "hyperdht": "^6.27.0",
    "typescript-eslint": "^8.46.4"
  },
  "overrides": {
    "@listam/protocol": "file:../listam-packages/packages/protocol",
    "@listam/domain": "file:../listam-packages/packages/domain",
    "@listam/logging": "file:../listam-packages/packages/logging",
    "@listam/secrets": "file:../listam-packages/packages/secrets",
    "@listam/grocery": "file:../listam-packages/packages/grocery",
    "@listam/i18n": "file:../listam-packages/packages/i18n",
    "@listam/owner-control": "file:../listam-packages/packages/owner-control",
    "@listam/client": "file:../listam-packages/packages/client",
    "@listam/backend": "file:../listam-packages/packages/backend"
  }
}
